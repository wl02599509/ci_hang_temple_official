<div data-controller="modal" style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 50; display: flex; align-items: center; justify-content: center;"
     data-action="click->modal#closeOnBackdrop">
  <div style="background: white; border-radius: 8px; padding: 2rem; width: 400px;"
       data-modal-target="dialog">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h3>繳費</h3>
      <button type="button" data-action="modal#close">✕</button>
    </div>

    <%= form_with url: pay_admin_activity_registrations_path(activity), method: :post do |f| %>
      <% registration_ids.each do |rid| %>
        <%= hidden_field_tag "registration_ids[]", rid %>
      <% end %>

      <div class="form-group" style="margin-bottom: 1rem;">
        <label class="form-label">繳費方式（必填）</label>
        <%= select_tag :payment_method,
              options_for_select([["轉帳", "transfer"], ["現金", "cash"]]),
              class: "form-input",
              include_blank: "請選擇繳費方式",
              required: true %>
      </div>

      <div class="form-group" style="margin-bottom: 1rem;">
        <label class="form-label">收款人（必填）</label>
        <%= text_field_tag :collector, nil,
              class: "form-input",
              placeholder: "請輸入收款人姓名",
              required: true %>
      </div>

      <div style="text-align: right; margin-top: 1.5rem;">
        <button type="button" class="btn btn-outline" data-action="modal#close">取消</button>
        <button type="submit" class="btn btn-primary">確定繳費</button>
      </div>
    <% end %>
  </div>
</div>
