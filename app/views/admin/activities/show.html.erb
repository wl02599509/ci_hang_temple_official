<div class="content-header">
  <h2><%= @activity.title %></h2>
  <div>
    <%= link_to "編輯", edit_admin_activity_path(@activity), class: "btn btn-secondary" %>
    <%= link_to "返回列表", admin_activities_path, class: "btn btn-outline" %>
  </div>
</div>

<div style="max-width: 720px;">
  <dl style="display: grid; grid-template-columns: 160px 1fr; gap: 0.75rem 1rem; margin-bottom: 1.5rem;">
    <dt style="font-weight: 600; color: #6b7280;">活動主題</dt>
    <dd><%= @activity.title %></dd>

    <dt style="font-weight: 600; color: #6b7280;">活動日期</dt>
    <dd><%= @activity.event_date.strftime("%Y-%m-%d") %></dd>

    <dt style="font-weight: 600; color: #6b7280;">報名期間</dt>
    <dd><%= @activity.registration_start_date.strftime("%Y-%m-%d") %> – <%= @activity.registration_end_date.strftime("%Y-%m-%d") %></dd>

    <dt style="font-weight: 600; color: #6b7280;">費用</dt>
    <dd>NT$ <%= number_with_delimiter(@activity.fee) %></dd>

    <dt style="font-weight: 600; color: #6b7280;">狀態</dt>
    <dd><%= t("zh-TW.activerecord.attributes.activity.statuses.#{@activity.status}") %></dd>

    <dt style="font-weight: 600; color: #6b7280;">活動描述</dt>
    <dd><%= @activity.description %></dd>

    <% if @activity.notes.present? %>
      <dt style="font-weight: 600; color: #6b7280;">備註</dt>
      <dd><%= @activity.notes %></dd>
    <% end %>
  </dl>

  <% if @activity.photos.attached? %>
    <h3 style="margin-bottom: 0.75rem;">活動照片</h3>
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
      <% @activity.photos.each do |photo| %>
        <%= image_tag photo, style: "width: 200px; height: 150px; object-fit: cover; border-radius: 4px;" %>
      <% end %>
    </div>
  <% end %>
</div>
