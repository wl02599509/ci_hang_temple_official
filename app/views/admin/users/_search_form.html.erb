<div class="search-card">
  <%= search_form_for @q, url: admin_users_path, method: :get do |f| %>
    <div class="search-grid">
      <div class="form-group">
        <%= f.label :status_eq, User.human_attribute_name(:status) %>
        <%= f.select :status_eq,
                     options_for_select(User.statuses.map { |key, value| [I18n.t("activerecord.attributes.user.statuses.#{key}"), key] }, @q.status_eq),
                     { include_blank: "全部" },
                     class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :name_cont, User.human_attribute_name(:name) %>
        <%= f.search_field :name_cont, placeholder: "請輸入姓名", class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :id_number_start, User.human_attribute_name(:id_number) %>
        <%= f.search_field :id_number_start, placeholder: "請輸入身分證字號", class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :sex_eq, User.human_attribute_name(:sex) %>
        <%= f.select :sex_eq,
                     options_for_select(User.sexes.map { |key, value| [I18n.t("activerecord.attributes.user.sexes.#{key}"), key] }, @q.sex_eq),
                     { include_blank: "全部" },
                     class: "form-control" %>
      </div>

      <div class="form-group">
        <%= f.label :zodiac_eq, User.human_attribute_name(:zodiac) %>
        <%= f.select :zodiac_eq,
                     options_for_select(User.zodiacs.map { |key, value| [I18n.t("activerecord.attributes.user.zodiacs.#{key}"), key] }, @q.zodiac_eq),
                     { include_blank: "全部" },
                     class: "form-control" %>
      </div>
    </div>

    <div class="search-actions">
      <%= link_to t('helpers.submit.clear'), admin_users_path, class: "btn btn-secondary" %>
      <%= f.submit t('helpers.submit.search'), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
