<div class="content-header">
  <h2><%= t(".title") %></h2>
</div>

<%= render "search_form" %>

<div class="table-toolbar">
  <% if policy(User).create? %>
    <%= link_to t("admin.users.actions.new"), new_admin_user_path, class: "btn btn-primary" %>
  <% end %>
  <% unless @users.empty? %>
    <%= link_to export_admin_users_path(q: params[:q]&.to_unsafe_h, format: :xlsx), class: "btn btn-export" do %>
      <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <%= t('.export_excel') %>
    <% end %>
  <% end %>
</div>

<div class="data-table-wrap">
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <% display_order_columns.each do |column| %>
            <th>
              <% if [:status, :sex, :zodiac].include?(column) %>
                <%= sort_link(@q, column, User.human_attribute_name(column), default_order: :asc) %>
              <% else %>
                <%= User.human_attribute_name(column) %>
              <% end %>
            </th>
          <% end %>
          <th><%= t(".actions_column") %></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <% display_order_columns.each do |column| %>
              <td>
                <%= respond_to?("display_#{column}") ? public_send("display_#{column}", user) : user.send(column) %>
              </td>
            <% end %>
            <td class="table-actions">
              <%= link_to t("admin.users.actions.view"), admin_user_path(user), class: "btn btn-sm btn-info" %>
              <% if policy(user).edit? %>
                <%= link_to t("admin.users.actions.edit"), edit_admin_user_path(user), class: "btn btn-sm btn-primary" %>
              <% end %>
              <% if policy(user).destroy? %>
                <%= button_to t("admin.users.actions.delete"), admin_user_path(user), method: :delete,
                  class: "btn btn-sm btn-secondary",
                  data: { turbo_confirm: t("admin.users.index.delete_confirm", name: user.name) } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @users.empty? %>
    <div class="table-empty">
      <p><%= t('.no_users') %></p>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="pagination-wrap">
    <%== @pagy.series_nav %>
  </div>
<% end %>
