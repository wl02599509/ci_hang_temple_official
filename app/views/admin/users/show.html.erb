<div class="content-header">
  <h2><%= t(".title") %></h2>
  <div>
    <%= link_to t("admin.users.actions.edit"), edit_admin_user_path(@user), class: "btn btn-primary" %>
    <%= link_to t("admin.users.actions.back"), admin_users_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="data-table-wrap">
  <table class="data-table">
    <tbody>
      <tr>
        <th><%= User.human_attribute_name(:id_number) %></th>
        <td><%= @user.id_number %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:name) %></th>
        <td><%= @user.name %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:phone_number) %></th>
        <td><%= @user.phone_number %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:birth_date) %></th>
        <td><%= @user.birth_date %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:sex) %></th>
        <td><%= display_sex(@user) %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:address) %></th>
        <td><%= @user.address %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:email) %></th>
        <td><%= @user.email %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:zodiac) %></th>
        <td><%= display_zodiac(@user) %></td>
      </tr>
      <tr>
        <th><%= User.human_attribute_name(:status) %></th>
        <td><%= display_status(@user) %></td>
      </tr>
    </tbody>
  </table>
</div>
